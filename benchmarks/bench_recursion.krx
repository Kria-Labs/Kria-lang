// Benchmark: Recursion
// Tests recursive function call overhead (Fibonacci 0..14)

fn fibonacci(n) {
    if (n <= 1) {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

set i = 0
set result = 0

while (i < 15) {
    set fib = fibonacci(i)
    set result = result + fib
    set i = i + 1
}

print(result)
