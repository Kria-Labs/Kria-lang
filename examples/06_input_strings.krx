print("=== String Input Examples ===")

set name = input<str>("What is your name?")
print("Hello, ")
print(name)

set surname = input<str>("What is your last name?")
print("Full name: ")
print(name)
print(" ")
print(surname)

set city = input<str>("Your city?")
print("City: ")
print(city)

set color = input<str>("Your favorite color?")
print("Your favorite color: ")
print(color)

set description = input<str>("Write a description:")
print("You wrote: ")
print(description)
